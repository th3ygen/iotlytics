# --- MQTT ---
MQTT_BROKER_URL=mqtt://localhost:8883
MQTT_USER=
MQTT_PWD=
# Topic namespace prefix: <prefix>/alert|status|awake/<deviceId>
MQTT_TOPIC_PREFIX=gajahsafe
# Verify the broker TLS certificate. Set to "false" to disable (not recommended).
MQTT_REJECT_UNAUTHORIZED=true

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
# Channel that receives the daily 24h heartbeat report
TELEGRAM_HEARTBEAT_CHANNEL_ID=-5248562860

# --- Localization ---
TIMEZONE=Asia/Kuala_Lumpur
LOCALE=en-MY

# --- Branding (used in Telegram message text) ---
APP_NAME=GajahSafe
APP_EMOJI=🐘

# --- Scheduling (hours 0-23, in TIMEZONE) ---
HEARTBEAT_REPORT_HOUR=3
# Comma-separated hours to send the device status summary
DEV_STATUS_HOURS=12,18

# --- Retry policy ---
MAX_RETRY_ATTEMPTS=30
RETRY_DELAY_MS=3000

# --- Devices ---
# Path to the JSON device registry (relative paths resolve from CWD)
DEVICES_CONFIG_PATH=devices.json
